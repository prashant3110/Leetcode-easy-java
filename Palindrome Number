class Solution {
    public boolean isPalindrome(int x) {

        int y=x;
        int reverse=0;
        while(y>0){
           int a=y%10;
            reverse = reverse*10+a;
            y=y/10;
        }

        if(x==reverse){
            return true;
        }
        else{
            return false;
        }

        
    }
}
