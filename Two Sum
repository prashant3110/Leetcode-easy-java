class Solution {
    public int[] twoSum(int[] nums, int target) {
        
        int size1 = nums.length;

        for(int i=0;i<size1;i++){
            for(int j = i+1 ; j<size1; j++){
                if(nums[i]+nums[j]==target){
                   return new int[] {i,j};
                }
            }
        }
        return new int []{-1,-1};
    }
}
